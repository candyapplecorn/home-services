#!/usr/bin/env bash
# Manage the home-services tmux session (dictation + moviewatch).
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SESSION="${JOES_SERVICES_TMUX_SESSION:-home-services}"
PATH_PREFIX="${JOES_SERVICES_PATH:-/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}"
export PATH="$PATH_PREFIX"
DICTATION_DIR="${JOES_SERVICES_DICTATION_DIR:-$ROOT/dictation}"
MOVIEWATCH_SCRIPT="${JOES_SERVICES_MOVIEWATCH_SCRIPT:-$ROOT/moviewatch/moviewatch2.sh}"
AI_HELPER_BIN="${HOME_SERVICES_AI_HELPER_BIN:-$ROOT/bin/ai-helper}"
APP_SUPPORT="${HOME_SERVICES_APP_SUPPORT:-$HOME/Library/Application Support/HomeServices}"
LOG_DIR="$APP_SUPPORT/logs"
MOVIEWATCH_LOG="$LOG_DIR/moviewatch.log"
DICTATION_STATE_FILE="$HOME/Library/Application Support/DictationRouter/state"
LAUNCH_AGENT_LABEL="${HOME_SERVICES_LAUNCH_AGENT_LABEL:-com.jburger.home-services}"
LAUNCH_AGENT_PLIST="${HOME_SERVICES_LAUNCH_AGENT_PLIST:-$HOME/Library/LaunchAgents/$LAUNCH_AGENT_LABEL.plist}"
DESKTOP_SHORTCUT="${HOME_SERVICES_DESKTOP_SHORTCUT:-$HOME/Desktop/Home Services.command}"

usage() {
  cat <<EOF
home-services - manage dictation-router + moviewatch2

Usage:
  home-services                 Start detached (no-op if already running)
  home-services start           Start detached
  home-services status          Print tmux service status
  home-services stop            Stop the tmux session
  home-services kill            Force-kill the tmux session
  home-services restart         Stop and recreate the tmux session
  home-services attach          Attach to the tmux session
  home-services logs            Print log file paths
  home-services doctor          Check runtime dependencies
  home-services install-startup Install a LaunchAgent that starts services at login
  home-services uninstall-startup
                                Remove the login LaunchAgent
  home-services startup-status  Print login LaunchAgent status
  home-services install-desktop-shortcut
                                Create a double-click Desktop launcher
  home-services ai-helper ...   Run the experimental on-demand AI helper
  home-services open-config     Open dictation/config.yaml
  home-services open-logs       Open the HomeServices log directory
  home-services -a              Backward-compatible alias for attach
  home-services -r              Backward-compatible alias for restart
  home-services --help          Show this help
EOF
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

tmux_exists() {
  command_exists tmux
}

session_exists() {
  tmux_exists && tmux has-session -t "$SESSION" 2>/dev/null
}

require_tmux() {
  tmux_exists || {
    echo "home-services: tmux not found. Run: $ROOT/install.sh" >&2
    exit 1
  }
}

require_runtime() {
  require_tmux
  [[ -x "$DICTATION_DIR/.venv/bin/dictation-router" ]] || {
    echo "home-services: dictation app is not installed. Run: $ROOT/install.sh" >&2
    exit 1
  }
  [[ -x "$MOVIEWATCH_SCRIPT" ]] || {
    echo "home-services: missing $MOVIEWATCH_SCRIPT" >&2
    exit 1
  }
}

dictation_tmux_command() {
  printf 'set +e; export PATH=%s; cd %q || exit 1; while true; do %q; status=$?; echo "home-services: dictation-router exited with status $status; restarting in 2s" >&2; sleep 2; done' \
    "$PATH_PREFIX" \
    "$DICTATION_DIR" \
    "$DICTATION_DIR/.venv/bin/dictation-router"
}

moviewatch_tmux_command() {
  printf 'set +e; export PATH=%s; %q 2>&1 | tee -a %q' \
    "$PATH_PREFIX" \
    "$MOVIEWATCH_SCRIPT" \
    "$MOVIEWATCH_LOG"
}

services_window_exists() {
  tmux list-panes -t "${SESSION}:services" >/dev/null 2>&1
}

pane_title_exists() {
  local title="$1"
  tmux list-panes -t "${SESSION}:services" -F '#{pane_title}' 2>/dev/null | grep -Fxq "$title"
}

add_service_pane() {
  local title="$1"
  local command="$2"
  local pane_id

  pane_id="$(tmux split-window -P -F '#{pane_id}' -t "${SESSION}:services" -v "$command")"
  tmux select-pane -t "$pane_id" -T "$title"
  tmux select-pane -t "$pane_id"
}

create_services_session() {
  local dictation_cmd moviewatch_cmd win pane_dictation pane_moviewatch
  dictation_cmd="$(dictation_tmux_command)"
  moviewatch_cmd="$(moviewatch_tmux_command)"
  win="${SESSION}:services"

  tmux new-session -d -s "$SESSION" -n services "$dictation_cmd"
  pane_dictation="$(tmux list-panes -t "$win" -F '#{pane_id}' | head -1)"
  tmux split-window -t "$pane_dictation" -v "$moviewatch_cmd"
  pane_moviewatch="$(tmux list-panes -t "$win" -F '#{pane_id}' | tail -1)"
  tmux select-pane -t "$pane_dictation" -T dictation
  tmux select-pane -t "$pane_moviewatch" -T moviewatch
  tmux select-pane -t "$pane_dictation"
}

start_services() {
  require_runtime
  mkdir -p "$LOG_DIR"

  if session_exists; then
    if ! services_window_exists; then
      tmux new-window -d -t "$SESSION" -n services "$(dictation_tmux_command)"
      tmux select-pane -t "${SESSION}:services.0" -T dictation
    fi

    local repaired=0
    if ! pane_title_exists dictation; then
      add_service_pane dictation "$(dictation_tmux_command)"
      repaired=1
    fi
    if ! pane_title_exists moviewatch; then
      add_service_pane moviewatch "$(moviewatch_tmux_command)"
      repaired=1
    fi

    if (( repaired )); then
      tmux select-layout -t "${SESSION}:services" even-vertical >/dev/null 2>&1 || true
      echo "home-services: repaired session '$SESSION' (dictation + moviewatch)"
    else
      echo "home-services: session '$SESSION' already running"
    fi
    return 0
  fi

  create_services_session
  echo "home-services: started session '$SESSION' (dictation + moviewatch)"
}

stop_services() {
  require_tmux
  if session_exists; then
    tmux kill-session -t "$SESSION"
    echo "home-services: stopped session '$SESSION'"
  else
    echo "home-services: session '$SESSION' is not running"
  fi
}

kill_services() {
  require_tmux
  if session_exists; then
    tmux kill-session -t "$SESSION"
    echo "home-services: killed session '$SESSION'"
  else
    echo "home-services: session '$SESSION' is not running"
  fi
}

restart_services() {
  require_tmux
  if session_exists; then
    tmux kill-session -t "$SESSION"
  fi
  start_services
}

attach_services() {
  start_services >/dev/null
  exec tmux attach-session -t "$SESSION"
}

status_services() {
  local dictation_state has_dictation=0 has_moviewatch=0

  if ! tmux_exists; then
    echo "status=missing-tmux"
    exit 2
  fi

  if ! session_exists; then
    echo "status=stopped"
    exit 1
  fi

  if services_window_exists && pane_title_exists dictation; then
    has_dictation=1
  fi
  if services_window_exists && pane_title_exists moviewatch; then
    has_moviewatch=1
  fi

  if (( has_dictation && has_moviewatch )); then
    echo "status=running"
  else
    echo "status=degraded"
    (( has_dictation )) || echo "missing=dictation"
    (( has_moviewatch )) || echo "missing=moviewatch"
  fi

  if (( has_dictation )) && [[ -r "$DICTATION_STATE_FILE" ]]; then
    dictation_state="$(sed -n '1p' "$DICTATION_STATE_FILE" | tr -d '[:space:]')"
    [[ -n "$dictation_state" ]] && echo "dictation_state=$dictation_state"
  fi
  tmux list-panes -t "${SESSION}:services" -F 'pane=#{pane_title} active=#{pane_active} command=#{pane_current_command}' 2>/dev/null || true

  if ! (( has_dictation && has_moviewatch )); then
    exit 3
  fi
}

logs_services() {
  echo "dictation_logs=$HOME/Library/Application Support/DictationRouter/logs"
  echo "dictation_transcripts=$HOME/Library/Application Support/DictationRouter/transcripts"
  echo "moviewatch_log=$MOVIEWATCH_LOG"
  echo "experimental_ai_helper_recordings=$HOME/Library/Application Support/HomeServices/ai-helper/recordings"
}

xml_escape() {
  local value="$1"
  value="${value//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  value="${value//\"/&quot;}"
  value="${value//\'/&apos;}"
  printf '%s' "$value"
}

write_startup_plist() {
  local launcher_path stdout_log stderr_log root_path path_value label_value
  launcher_path="$(xml_escape "$ROOT/bin/home-services")"
  stdout_log="$(xml_escape "$LOG_DIR/launchagent.out.log")"
  stderr_log="$(xml_escape "$LOG_DIR/launchagent.err.log")"
  root_path="$(xml_escape "$ROOT")"
  path_value="$(xml_escape "$PATH_PREFIX")"
  label_value="$(xml_escape "$LAUNCH_AGENT_LABEL")"

  mkdir -p "$(dirname "$LAUNCH_AGENT_PLIST")" "$LOG_DIR"
  cat > "$LAUNCH_AGENT_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label_value</string>
  <key>ProgramArguments</key>
  <array>
    <string>$launcher_path</string>
    <string>start</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME_SERVICES_ROOT</key>
    <string>$root_path</string>
    <key>PATH</key>
    <string>$path_value</string>
  </dict>
  <key>StandardOutPath</key>
  <string>$stdout_log</string>
  <key>StandardErrorPath</key>
  <string>$stderr_log</string>
</dict>
</plist>
EOF
}

launchctl_domain() {
  printf 'gui/%s' "$(id -u)"
}

install_startup() {
  write_startup_plist

  if [[ "${HOME_SERVICES_SKIP_LAUNCHCTL:-0}" == "1" ]]; then
    echo "home-services: wrote startup task plist (launchctl skipped)"
    echo "startup_plist=$LAUNCH_AGENT_PLIST"
    return 0
  fi

  command_exists launchctl || {
    echo "home-services: launchctl not found" >&2
    exit 1
  }

  local domain
  domain="$(launchctl_domain)"
  launchctl bootout "$domain/$LAUNCH_AGENT_LABEL" >/dev/null 2>&1 || true
  launchctl bootout "$domain" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "$domain" "$LAUNCH_AGENT_PLIST"
  launchctl enable "$domain/$LAUNCH_AGENT_LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "$domain/$LAUNCH_AGENT_LABEL" >/dev/null 2>&1 || true

  echo "home-services: installed startup task '$LAUNCH_AGENT_LABEL'"
  echo "startup_plist=$LAUNCH_AGENT_PLIST"
  echo "startup_stdout=$LOG_DIR/launchagent.out.log"
  echo "startup_stderr=$LOG_DIR/launchagent.err.log"
}

uninstall_startup() {
  if [[ "${HOME_SERVICES_SKIP_LAUNCHCTL:-0}" != "1" ]] && command_exists launchctl; then
    local domain
    domain="$(launchctl_domain)"
    launchctl bootout "$domain/$LAUNCH_AGENT_LABEL" >/dev/null 2>&1 || true
    launchctl bootout "$domain" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  fi

  rm -f "$LAUNCH_AGENT_PLIST"
  echo "home-services: removed startup task '$LAUNCH_AGENT_LABEL'"
}

startup_status() {
  echo "startup_label=$LAUNCH_AGENT_LABEL"
  if [[ -f "$LAUNCH_AGENT_PLIST" ]]; then
    echo "startup_installed=yes"
    echo "startup_plist=$LAUNCH_AGENT_PLIST"
  else
    echo "startup_installed=no"
  fi

  if [[ "${HOME_SERVICES_SKIP_LAUNCHCTL:-0}" == "1" ]]; then
    echo "startup_loaded=unknown"
  elif command_exists launchctl && launchctl print "$(launchctl_domain)/$LAUNCH_AGENT_LABEL" >/dev/null 2>&1; then
    echo "startup_loaded=yes"
  else
    echo "startup_loaded=no"
  fi
}

install_desktop_shortcut() {
  local launcher_cmd
  printf -v launcher_cmd '%q' "$ROOT/bin/home-services"

  mkdir -p "$(dirname "$DESKTOP_SHORTCUT")"
  cat > "$DESKTOP_SHORTCUT" <<EOF
#!/usr/bin/env bash
exec $launcher_cmd attach
EOF
  chmod +x "$DESKTOP_SHORTCUT"

  echo "home-services: installed Desktop launcher"
  echo "desktop_shortcut=$DESKTOP_SHORTCUT"
}

doctor_services() {
  local failed=0

  check_command() {
    local name="$1"
    if command_exists "$name"; then
      echo "ok: $name ($(command -v "$name"))"
    else
      echo "missing: $name"
      failed=1
    fi
  }

  check_path() {
    local label="$1"
    local path="$2"
    if [[ -e "$path" ]]; then
      echo "ok: $label ($path)"
    else
      echo "missing: $label ($path)"
      failed=1
    fi
  }

  check_command tmux
  check_command ffmpeg
  check_command ffprobe
  check_command bc
  check_command whisper-cli
  check_path dictation-router "$DICTATION_DIR/.venv/bin/dictation-router"
  check_path moviewatch "$MOVIEWATCH_SCRIPT"
  check_path "default Whisper model" "$HOME/.cache/whisper-cpp/ggml-medium.en.bin"

  if [[ -x "$AI_HELPER_BIN" ]]; then
    echo "experimental: ai-helper wrapper present ($AI_HELPER_BIN)"
  else
    echo "experimental: ai-helper wrapper not installed"
  fi

  if (( failed )); then
    echo "home-services: doctor found missing items"
    exit 1
  fi
  echo "home-services: doctor passed"
}

open_config() {
  open "$ROOT/dictation/config.yaml"
}

open_logs() {
  mkdir -p "$LOG_DIR"
  open "$LOG_DIR"
}

run_ai_helper() {
  exec "$AI_HELPER_BIN" "$@"
}

cmd="${1:-start}"
case "$cmd" in
  start) start_services ;;
  status) status_services ;;
  stop) stop_services ;;
  kill) kill_services ;;
  restart) restart_services ;;
  attach) attach_services ;;
  logs) logs_services ;;
  doctor) doctor_services ;;
  install-startup) install_startup ;;
  uninstall-startup) uninstall_startup ;;
  startup-status) startup_status ;;
  install-desktop-shortcut) install_desktop_shortcut ;;
  ai-helper) shift; run_ai_helper "$@" ;;
  open-config) open_config ;;
  open-logs) open_logs ;;
  -a|--attach) attach_services ;;
  -r|--restart) restart_services ;;
  -h|--help|help) usage ;;
  *) echo "home-services: unknown command $cmd" >&2; usage >&2; exit 1 ;;
esac
